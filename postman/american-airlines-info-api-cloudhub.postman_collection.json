      "name": "Flights API",
      "item": [
        {
          "name": "Get All Flights",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "client_id",
                "value": "{{clientId}}",
                "disabled": true
              },
              {
                "key": "client_secret",
                "value": "{{clientSecret}}",
                "disabled": true
              }
            ],
            "description": "cURL:\\n\\ncurl --request GET '{{baseUrl}}/api/flights' \\\\\\n--header 'Accept: application/json'",
            "url": {
              "raw": "{{baseUrl}}/api/flights",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "flights"
              ]
