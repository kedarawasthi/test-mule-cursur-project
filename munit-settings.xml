<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 https://maven.apache.org/xsd/settings-1.0.0.xsd">
  <servers>
    <server>
      <id>mulesoft-releases</id>
      <username>~~~Client~~~</username>
      <password>${env.ANYPOINT_CONNECTED_APP_CLIENT_ID}~?~${env.ANYPOINT_CONNECTED_APP_CLIENT_SECRET}</password>
    </server>
    <server>
      <id>mulesoft-ee-releases</id>
      <username>~~~Client~~~</username>
      <password>${env.ANYPOINT_CONNECTED_APP_CLIENT_ID}~?~${env.ANYPOINT_CONNECTED_APP_CLIENT_SECRET}</password>
    </server>
    <server>
      <id>anypoint-exchange-v3</id>
      <username>~~~Client~~~</username>
      <password>${env.ANYPOINT_CONNECTED_APP_CLIENT_ID}~?~${env.ANYPOINT_CONNECTED_APP_CLIENT_SECRET}</password>
    </server>
  </servers>
  <profiles>
    <profile>
      <id>munit-repos</id>
      <repositories>
        <repository>
          <id>central</id>
          <url>https://repo.maven.apache.org/maven2</url>
          <releases><enabled>true</enabled></releases>
          <snapshots><enabled>false</enabled></snapshots>
        </repository>
        <repository>
          <id>mulesoft-releases</id>
          <url>https://repository.mulesoft.org/releases/</url>
          <releases><enabled>true</enabled></releases>
          <snapshots><enabled>false</enabled></snapshots>
        </repository>
        <repository>
          <id>mulesoft-ee-releases</id>
          <url>https://repository.mulesoft.org/nexus/content/repositories/releases-ee/</url>
          <releases><enabled>true</enabled></releases>
          <snapshots><enabled>false</enabled></snapshots>
        </repository>
      </repositories>
      <pluginRepositories>
        <pluginRepository>
          <id>central</id>
          <url>https://repo.maven.apache.org/maven2</url>
          <releases><enabled>true</enabled></releases>
          <snapshots><enabled>false</enabled></snapshots>
        </pluginRepository>
        <pluginRepository>
          <id>mulesoft-releases</id>
          <url>https://repository.mulesoft.org/releases/</url>
          <releases><enabled>true</enabled></releases>
          <snapshots><enabled>false</enabled></snapshots>
        </pluginRepository>
      </pluginRepositories>
    </profile>
  </profiles>
  <activeProfiles>
    <activeProfile>munit-repos</activeProfile>
  </activeProfiles>
</settings>
